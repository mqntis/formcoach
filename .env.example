# FormCoach Environment Variables
# Copy this file to .env and fill in your real values
# DO NOT put real secrets in this file

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=
FLASK_DEBUG=1

# Database
DATABASE_URL=

# OpenAI (for AI form coaching features)
OPENAI_API_KEY=

# JWT
JWT_SECRET_KEY=

# CORS
FRONTEND_URL=http://localhost:3000
