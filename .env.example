# FormCoach Environment Variables
# Copy this file to .env and fill in your real values
# DO NOT put real secrets in this file

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=
FLASK_DEBUG=1

# Database
DATABASE_URL=

# OpenAI (for AI form coaching features)
OPENAI_API_KEY=

# JWT
JWT_SECRET_KEY=

# CORS
FRONTEND_URL=http://localhost:3000

# Butterbase
BUTTERBASE_API_KEY=
BUTTERBASE_APP_ID=
BUTTERBASE_API_BASE=https://api.butterbase.ai

# IonRouter
IONROUTER_API_KEY=

# Seadance
SEADANCE_API_KEY=

# Photon
PHOTON_PROJECT_ID=
PHOTON_SECRET_KEY=

